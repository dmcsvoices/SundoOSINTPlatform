# Copy to .env and edit values before first run

# ── Graph / DB ──────────────────────────────────────────
# Neo4j listens on all interfaces (0.0.0.0) for Tailscale access.
# When installing Neo4j, set server.bolt.listen_address=0.0.0.0:17687 in neo4j.conf
NEO4J_URI=bolt://0.0.0.0:17687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

SQLITE_PATH=/home/darren/sundo-pi/data/sundo.db

REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_DB=0

# ── Outbound alerts ───────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=sundo@pi.local
SMTP_TO=operator@example.com

NTFY_TOPIC=sundo-alerts-changeme
NTFY_URL=https://ntfy.sh

# ── API keys (leave blank to disable source) ──────────
X_BEARER_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Detection tuning ────────────────────────────────────
BURST_WINDOW_MINUTES=30
BURST_THRESHOLD_ACCOUNTS=5
SIMILARITY_THRESHOLD=0.70
NUM_PERM=128
ALERT_MIN_ACCOUNTS=10
ALERT_MIN_PAYMENT_USD=10000

# ── Watch-lists (comma-separated) ─────────────────────
WATCHLIST_HASHTAGS=#StandWithIsrael,#Israel,#BringThemHome,#HamasIsISIS,#DefendIsrael
SEED_ORGS=American Israel Public Affairs Committee,Anti-Defamation League,Jewish Federations of North America,Israel on Campus Coalition,Zionist Organization of America,Stand With Us,Foundation for Defense of Democracies
SEED_VOICES=@eye.on.palestine,@palestine.chronicle,@qudsnen,@mondoweiss,@electronicintifada,@btselem,@palestinelegal,@adalahcenter

# ── RSS feeds (comma-separated) ─────────────────────────
AMPLIFY_FEEDS=https://feeds.mondoweiss.net/mondoweiss,https://electronicintifada.net/rss.xml,https://www.btselem.org/rss
MONITOR_FEEDS=https://rss.cnn.com/rss/edition.rss,https://feeds.bbci.co.uk/news/rss.xml

# ── Network / Privacy ───────────────────────────────────
TOR_PROXY=

# ── Dashboard ───────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=15000
FLASK_DEBUG=False

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
